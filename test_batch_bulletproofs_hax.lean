  let _ := if Hax.bne lhs rhs then
  ControlFlow.Break false
else
  ()
  let y_inv := scalar_inv y
  let y_inv_powers := powers_of_scalar y_inv n
  let h_prime := Hax.repeat_ IDENTITY (0 : Int)
  let i := (0 : Int)
  let _wf := Hax.whileFold (h_prime, i) (fun _ => true) fun (h_prime, i) =>
