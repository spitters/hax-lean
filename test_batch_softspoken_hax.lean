def shift_rows (state : Array (Int)) :=
  let result := Hax.repeat_ (0 : Int) (16 : Int)
  let _ := Hax.foldRange (0 : Int) (4 : Int) () fun col _acc =>
    let _ := 
      Hax.foldRange (0 : Int) (4 : Int) result fun row result =>
        Hax.array_update result (Hax.add row (Hax.mul (4 : Int) col)) (Hax.index state (Hax.add row (Hax.mul (4 : Int) (Hax.rem (Hax.add col row) (4 : Int)))))
    ()
  result

def mix_columns (state : Array (Int)) :=
  let result := Hax.repeat_ (0 : Int) (16 : Int)
  Hax.foldRange (0 : Int) (4 : Int) result fun col result =>
    let s0 := Hax.index state (Hax.mul (4 : Int) col)
    let s1 := Hax.index state (Hax.add (Hax.mul (4 : Int) col) (1 : Int))
    let s2 := Hax.index state (Hax.add (Hax.mul (4 : Int) col) (2 : Int))
    let s3 := Hax.index state (Hax.add (Hax.mul (4 : Int) col) (3 : Int))
    let result := Hax.array_update result (Hax.mul (4 : Int) col) (Hax.bitxor (Hax.bitxor (Hax.bitxor (gf_mul2 s0) (gf_mul3 s1)) s2) s3)
    let result := Hax.array_update result (Hax.add (Hax.mul (4 : Int) col) (1 : Int)) (Hax.bitxor (Hax.bitxor (Hax.bitxor s0 (gf_mul2 s1)) (gf_mul3 s2)) s3)
    let result := Hax.array_update result (Hax.add (Hax.mul (4 : Int) col) (2 : Int)) (Hax.bitxor (Hax.bitxor (Hax.bitxor s0 s1) (gf_mul2 s2)) (gf_mul3 s3))
    let result := Hax.array_update result (Hax.add (Hax.mul (4 : Int) col) (3 : Int)) (Hax.bitxor (Hax.bitxor (Hax.bitxor (gf_mul3 s0) s1) s2) (gf_mul2 s3))
    result

def aes128_key_expand (key : Array (Int)) :=
  let round_keys := Hax.repeat_ (Hax.repeat_ (0 : Int) (16 : Int)) (11 : Int)
  let round_keys := Hax.array_update round_keys (0 : Int) key
  Hax.foldRange (1 : Int) (10 : Int) round_keys fun round round_keys =>
    let prev := Hax.index round_keys (Hax.sub round (1 : Int))
    let rk := Hax.repeat_ (0 : Int) (16 : Int)
    let rot := #[Hax.index prev (13 : Int), Hax.index prev (14 : Int), Hax.index prev (15 : Int), Hax.index prev (12 : Int)]
    let rk := Hax.foldRange (0 : Int) (4 : Int) rk fun j rk =>
      let sbox_out := Hax.index SBOX (Hax.castVal (Hax.index rot j))
      if Hax.beq j (0 : Int) then
                let rk := Hax.array_update rk j (Hax.bitxor (Hax.bitxor (Hax.index prev j) sbox_out) (Hax.index RCON (Hax.sub round (1 : Int))))
        rk
      else
                let rk := Hax.array_update rk j (Hax.bitxor (Hax.index prev j) sbox_out)
        rk
    let rk := Hax.foldRange (4 : Int) (16 : Int) rk fun j rk =>
      Hax.array_update rk j (Hax.bitxor (Hax.index rk (Hax.sub j (4 : Int))) (Hax.index prev j))
    let round_keys := Hax.array_update round_keys round rk
    round_keys

def aes128_encrypt (key : Array (Int)) (plaintext : Array (Int)) :=
  let round_keys := aes128_key_expand key
  let state := Hax.repeat_ (0 : Int) (16 : Int)
  let state := Hax.foldRange (0 : Int) (16 : Int) state fun i state =>
    Hax.array_update state i (Hax.bitxor (Hax.index plaintext i) (Hax.index (Hax.index round_keys (0 : Int)) i))
  let state := Hax.foldRange (1 : Int) (9 : Int) state fun round state =>
    let state := Hax.foldRange (0 : Int) (16 : Int) state fun i state =>
      Hax.array_update state i (Hax.index SBOX (Hax.castVal (Hax.index state i)))
    let state := shift_rows state
    let state := mix_columns state
    Hax.foldRange (0 : Int) (16 : Int) state fun i state =>
      Hax.array_update state i (Hax.bitxor (Hax.index state i) (Hax.index (Hax.index round_keys round) i))
  let state := Hax.foldRange (0 : Int) (16 : Int) state fun i state =>
    Hax.array_update state i (Hax.index SBOX (Hax.castVal (Hax.index state i)))
  let state := shift_rows state
  Hax.foldRange (0 : Int) (16 : Int) state fun i state =>
    Hax.array_update state i (Hax.bitxor (Hax.index state i) (Hax.index (Hax.index round_keys (10 : Int)) i))

