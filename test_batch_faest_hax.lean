def faest_sign (secret_key : Array (Int) × (Array (Int) × Array (Int))) (msg : Array (Int)) (seed : Array (Int)) :=
  let depth := TREE_DEPTH
  let num_wires := NUM_WIRES
  let mu := compute_mu («.pk» secret_key) msg
  let (root_seed, iv) := derive_randomness («.sk» secret_key) mu seed
  let commitment := voleitH_commit («.sk» secret_key) («.owf_input» («.pk» secret_key)) root_seed iv depth num_wires
  let hcom := «VoleitHCommitment.hcom» commitment
  let masked_values := clone («.masked_values» commitment)
  let chall1 := compute_challenge_1 mu (#[hcom]) (Hax.deref masked_values) iv
  let hv := Hax.repeat_ (0 : Int) (32 : Int)
  let chall2 := compute_challenge_2 chall1 (Hax.deref masked_values) hv (Hax.deref masked_values)
  let challenge_indices := (compute_challenge_3 chall2 ZERO_WORD ZERO_WORD).1
  let decommitments := Hax.with_capacity TAU
  let batch_proofs := Hax.with_capacity TAU
  let com_j := Hax.with_capacity TAU
  let _ := Hax.foldRange (0 : Int) TAU () fun t _acc =>
    let _ := 
      let idx := 
        if Hax.lt t (Hax.array_len challenge_indices) then
          Hax.rem (Hax.index challenge_indices t) (Hax.shl (1 : Int) depth)
        else
          (0 : Int)
      let response := voleitH_respond commitment idx chall1 iv depth
      let _ := Hax.push batch_proofs («.batch_proof» response)
      let _ := Hax.push decommitments («.decommitment» response)
      Hax.push com_j («VoleitHResponse.com_j» response)
    ()
  FaestSignature iv (Hax.into_vec (#[hcom])) masked_values batch_proofs decommitments com_j

