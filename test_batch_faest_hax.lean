def voleitH_respond (commitment : Array (Int) × Array Int × Array (Int) × Array Int × Array Int × Array Int) (challenge_index : Int) (qs_challenge : Array (Int)) (iv : Array (Int)) (depth : Int) :=
  let num_wires := Hax.array_len («.masked_values» commitment)
  let decommitment := vole_decommit («VoleitHCommitment.root» commitment) depth challenge_index
  let recon := vole_reconstruct decommitment depth num_wires iv
  let gates := aes128_mul_gates
  let check_val := ZERO_WORD
  let chi_power := 
    let one := ZERO_WORD
    let one := Hax.array_update one (0 : Int) (1 : Int)
    one
  let (check_val, chi_power) := Hax.foldRange (0 : Int) (Hax.array_len gates) (check_val, chi_power) fun gi (check_val, chi_power) =>
    let w_a := gf128_add (Hax.index («.masked_values» commitment) («.input_a» (Hax.index gates gi))) (Hax.index («.keys» recon) («.input_a» (Hax.index gates gi)))
    let w_b := gf128_add (Hax.index («.masked_values» commitment) («.input_b» (Hax.index gates gi))) (Hax.index («.keys» recon) («.input_b» (Hax.index gates gi)))
    let w_c := gf128_add (Hax.index («.masked_values» commitment) («.output_c» (Hax.index gates gi))) (Hax.index («.keys» recon) («.output_c» (Hax.index gates gi)))
    let wa_wb := gf128_mul w_a w_b
    let error := gf128_add wa_wb w_c
    let scaled := gf128_mul chi_power error
    let check_val := gf128_add check_val scaled
    let chi_power := gf128_mul chi_power qs_challenge
    (check_val, chi_power)
  let batch_proof := check_val
  let opened_leaf := Hax.index («VoleitHCommitment.leaves» commitment) challenge_index
  let com_j := hash_commitment opened_leaf iv
  VoleitHResponse decommitment batch_proof com_j

