  let depth := TREE_DEPTH
  let num_wires := NUM_WIRES
  let mu := compute_mu pk msg
  let chall1 := compute_challenge_1 mu (Hax.deref («FaestSignature.hcom» sig)) (Hax.deref («FaestSignature.d» sig)) («.iv» sig)
